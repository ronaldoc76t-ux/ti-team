# CMDB ServiceNow Discovery - Environment Variables Template
# Copy this file to .env and fill in the values

# =====================================================
# SERVICE NOW CONFIGURATION
# =====================================================

# ServiceNow Instance (without .service-now.com)
# Example: "company" for "company.service-now.com"
SERVICENOW_INSTANCE=

# ServiceNow Credentials
# Use a service account with CMDB write permissions
SERVICENOW_USER=
SERVICENOW_PASS=

# =====================================================
# VMWARE VCENTER CONFIGURATION
# =====================================================

VCENTER_HOST=
VCENTER_USER=
VCENTER_PASS=

# DR Site (optional)
# VCENTER_HOST_DR=
# VCENTER_USER_DR=
# VCENTER_PASS_DR=

# =====================================================
# OPENSHIFT CONFIGURATION
# =====================================================

# API URL (including protocol and port)
OPENSHIFT_API_URL=https://api.openshift.example.com:6443

# Service Account Token
# Create a service account with read-only permissions:
# oc create serviceaccount cmdb-discovery -n default
# oc policy add-cluster-role-to-user view system:serviceaccount:default:cmdb-discovery
OPENSHIFT_TOKEN=

# Stage/DR Cluster (optional)
# OPENSHIFT_API_URL_STAGE=
# OPENSHIFT_TOKEN_STAGE=

# =====================================================
# BARE METAL DISCOVERY
# =====================================================

# SNMP Community (for each target subnet)
# SNMP_COMMUNITY=public

# SSH Credentials (if using SSH fallback)
# SSH_PASSWORD=

# =====================================================
# DISCOVERY SETTINGS
# =====================================================

# Schedule Mode
# Set to "true" for scheduled (24h) execution
SCHEDULED_MODE=false

# Config Path
CONFIG_PATH=/opt/cmdb-discovery/config/config.yaml

# Log File
LOG_FILE=/var/log/cmdb-discovery.log

# =====================================================
# ADVANCED (usually no need to change)
# =====================================================

# Python path
# PYTHON_PATH=/usr/local/bin

# Debug mode
# DEBUG=false